# Development-only settings for `npm run dev`.
# These are read by the Vite dev-server proxy (vite.config.ts) and are NEVER
# bundled into the app. Do not add VITE_-prefixed secrets — VITE_ vars are
# inlined into the public client bundle.

# Your Cortex instance (backend URL, no trailing slash)
CORTEX_DEV_URL=http://localhost:8000

# A read-scoped API key from that instance (Settings → API Keys).
# cortex_ro_… is enough for search/ask; use cortex_rw_… only if your app
# declares keyScope: "read_write".
CORTEX_DEV_KEY=
