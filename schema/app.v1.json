{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.cortex.eco/schema/app.v1.json",
  "title": "Cortex App Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "type",
    "description",
    "publisher",
    "icon",
    "cortex"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "maxLength": 64,
      "description": "Kebab-case slug, globally unique in the registry"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(-[0-9A-Za-z.-]+)?$",
      "description": "Semver"
    },
    "type": {
      "enum": [
        "static",
        "platform",
        "service"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "icon": {
      "type": "string",
      "description": "Path to an SVG icon inside the package"
    },
    "entry": {
      "type": "string",
      "default": "index.html",
      "description": "HTML entry inside dist/. Required for static and platform apps."
    },
    "cortex": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minVersion",
        "keyScope",
        "endpoints",
        "collections"
      ],
      "properties": {
        "minVersion": {
          "type": "string"
        },
        "keyScope": {
          "enum": [
            "read",
            "read_write"
          ]
        },
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+(/[a-z0-9_{}-]+)*$"
          },
          "description": "Cortex API paths (relative to /api/) the proxy will allow"
        },
        "collections": {
          "oneOf": [
            {
              "enum": [
                "user-selected",
                "all"
              ]
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          ]
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "description": "Platform apps only. Each declared capability is shown to the admin at install.",
      "properties": {
        "tasks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        },
        "http": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hosts"
          ],
          "properties": {
            "hosts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "llm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        },
        "features": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        },
        "branding": {
          "type": "object",
          "additionalProperties": false,
          "properties": {}
        }
      }
    },
    "config": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "description": {
            "type": "string",
            "maxLength": 200
          },
          "type": {
            "enum": [
              "text",
              "secret"
            ]
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "auth_header": {
            "type": "string",
            "description": "Header template for server-side injection, e.g. 'Authorization: Token PAPERLESS_TOKEN'"
          },
          "auth_host": {
            "type": "string",
            "minLength": 1,
            "description": "Restrict this var's auth_header to one host (literal hostname/URL or ${CONFIG_VAR} reference). Without it the header is injected on EVERY platform http call \u2014 declare it whenever the app talks to more than one host."
          }
        }
      }
    },
    "externalHosts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Hosts the browser may call directly (CSP connect-src). ${VAR} references to config values allowed."
    },
    "sharing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "links": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "users": {
      "type": "boolean",
      "default": false,
      "description": "Reserved: app-level user accounts (Stage 2). Runtime ignores in v1."
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "description": "Service apps only",
      "required": [
        "image"
      ],
      "properties": {
        "image": {
          "type": "string"
        },
        "compose": {
          "type": "string"
        },
        "requiredKeyScope": {
          "enum": [
            "read",
            "read_write",
            "delegated-provisioning"
          ]
        }
      }
    },
    "appContext": {
      "description": "Reserved for future use (server-injected context blocks). Runtime ignores in v1."
    },
    "pricing": {
      "description": "Reserved for future use (x402 monetization). Runtime ignores in v1."
    },
    "signatures": {
      "description": "Reserved for future use (publisher signing). Runtime ignores in v1."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "service"
          }
        }
      },
      "then": {
        "required": [
          "service"
        ]
      },
      "else": {
        "required": [
          "entry"
        ],
        "not": {
          "required": [
            "service"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "not": {
              "const": "platform"
            }
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "capabilities"
          ]
        }
      }
    }
  ]
}